{
    "name": "fns",
    "type": "module",
    "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test ./test/video-intelligence.test.mjs",
    "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "emails:export": "node ./scripts/export-marketing-emails.mjs",
        "emails:audit": "node ./scripts/export-all-registered-emails.mjs",
        "campaign:prepare": "node ./scripts/prepare-campaign-recipients.mjs",
        "campaign:sync": "node ./scripts/sync-brevo-contacts.mjs",
        "campaign:create": "node ./scripts/create-brevo-campaign.mjs",
        "campaign:send": "node ./scripts/send-brevo-campaign.mjs"
    },
    "engines": {
        "node": "20"
    },
    "main": "lib/index.js",
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "firebase-admin": "^12.0.0",
        "firebase-functions": "^6.0.0"
    },
    "devDependencies": {
        "typescript": "^5.2.2"
    },
    "private": true
}
