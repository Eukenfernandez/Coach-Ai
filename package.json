{
  "name": "coach-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsx scripts/generate-public-media.ts && vite build && tsx scripts/generate-seo-pages.tsx",
    "preview": "vite preview",
    "test": "npm --prefix fns test",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && npx electron-builder --win --x64",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "vite build && npx cap sync android",
    "cap:sync:android": "vite build && npx cap sync android",
    "cap:sync:ios": "vite build && npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "cap:doctor": "npx cap doctor",
    "cap:build:android": "vite build && npx cap sync android && cd android && gradlew.bat assembleDebug"
  },
  "build": {
    "appId": "com.coachai.app",
    "productName": "Coach AI",
    "directories": {
      "output": "el-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "pub/icons/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "pub/icons/icon.ico",
      "publisherName": "Coach AI"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "pub/icons/icon.ico",
      "uninstallerIcon": "pub/icons/icon.ico",
      "installerHeaderIcon": "pub/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Coach AI",
      "artifactName": "Coach-AI-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@google/genai": "^0.2.0",
    "@mediapipe/tasks-vision": "^0.10.22-rc.20250304",
    "clsx": "^2.1.0",
    "firebase": "^10.8.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "terser": "^5.44.1",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.4"
  }
}
