
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPER FUNCTIONS ==========

    // Check if caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Check if caller owns this document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Check if caller is the master admin account
    function isAdmin() {
      return isAuth() && request.auth.uid == 'MASTER_GOD_EUKEN';
    }

    // Check if coach has an accepted relationship with this athlete
    function isAcceptedCoach(athleteId) {
      return isAuth() && exists(/databases/$(database)/documents/requests/$(request.auth.uid + '_' + athleteId))
        && get(/databases/$(database)/documents/requests/$(request.auth.uid + '_' + athleteId)).data.status == 'accepted';
    }

    // ========== USER PROFILES ==========
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ========== USER DATA (videos, plans, records) ==========
    match /userdata/{uid} {
      allow read: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
      allow write: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();

      // Video subcollection
      match /videos/{videoId} {
        allow read: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
        allow write: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
      }

      // Plans subcollection
      match /plans/{planId} {
        allow read: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
        allow write: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
      }

      // Video intelligence context generated by backend
      match /videoContexts/{videoId} {
        allow read: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
        allow write: if false;

        match /segments/{segmentId} {
          allow read: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
          allow write: if false;
        }

        match /chatSessions/{sessionId} {
          allow read: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
          allow write: if false;

          match /messages/{messageId} {
            allow read: if isOwner(uid) || isAcceptedCoach(uid) || isAdmin();
            allow write: if false;
          }
        }
      }
    }

    // ========== COACH-ATHLETE REQUESTS (canonical relationship) ==========
    match /requests/{requestId} {
      // Anyone authenticated can read requests they are involved in
      allow read: if isAuth();
      // Coach can create/update requests where they are the coach
      allow create: if isAuth() && request.resource.data.coachId == request.auth.uid;
      // Coach or athlete can update status (accept/reject)
      allow update: if isAuth() && (
        resource.data.coachId == request.auth.uid ||
        resource.data.athleteId == request.auth.uid
      );
    }

    // ========== QUOTA COUNTERS (server-managed, read-only for clients) ==========
    match /quota_counters/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      // Only Cloud Functions should write to this collection
      // Client writes are denied.
      allow write: if false;
    }

    // ========== SUBSCRIPTION & STRIPE (managed by extension + Cloud Functions) ==========
    match /customers/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();

      match /{subcollection=**} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) || isAdmin();
      }
    }

    // ========== ACCOUNT ENFORCEMENT (server-managed) ==========
    match /account_enforcement/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // ========== NOTIFICATIONS ==========
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if false; // Only Cloud Functions
    }

    // ========== AI ANALYSIS LOGS (server-managed) ==========
    match /ai_analysis_logs/{logId} {
      allow read: if false;
      allow write: if false; // Only Cloud Functions
    }
  }
}
