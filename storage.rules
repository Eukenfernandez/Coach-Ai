
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ========== PUBLIC ASSETS (landing video, etc.) ==========
    match /pub/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'MASTER_GOD_EUKEN';
    }

    // ========== USER VIDEOS ==========
    // Path pattern: videos/{userId}/{filename}
    match /videos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.uid == 'MASTER_GOD_EUKEN' ||
        // Coach with accepted relationship can upload to athlete's folder
        firestore.exists(/databases/(default)/documents/requests/$(request.auth.uid + '_' + userId))
        && firestore.get(/databases/(default)/documents/requests/$(request.auth.uid + '_' + userId)).data.status == 'accepted'
      );
    }

    // ========== USER PLANS (PDFs) ==========
    // Path pattern: plans/{userId}/{filename}
    match /plans/{userId}/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.uid == 'MASTER_GOD_EUKEN' ||
        // Check accepted relationship for read access
        firestore.exists(/databases/(default)/documents/requests/$(request.auth.uid + '_' + userId))
        && firestore.get(/databases/(default)/documents/requests/$(request.auth.uid + '_' + userId)).data.status == 'accepted'
      );
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.uid == 'MASTER_GOD_EUKEN' ||
        // Coach with accepted relationship can upload to athlete's folder
        firestore.exists(/databases/(default)/documents/requests/$(request.auth.uid + '_' + userId))
        && firestore.get(/databases/(default)/documents/requests/$(request.auth.uid + '_' + userId)).data.status == 'accepted'
      );
    }

    // ========== CATCH-ALL: Deny everything else ==========
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
